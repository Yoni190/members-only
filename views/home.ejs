<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home</title>
</head>
<body>
    <h1>Home</h1>
    <a href="/account">Account</a>
    <% posts.forEach((post) => { %>
        <div>
            <h2><%= post.title %></h2>
            <p><%= post.message %></p>
            <p><%= post.timestamp %></p>
        </div>
    <% }) %>
</body>
</html>