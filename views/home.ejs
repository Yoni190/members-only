<div class="d-flex flex-column">
    <div class="d-flex gap-3 p-5">
        <% if(posts.length === 0) { %>
            <p>There are no posts. Be the first to post!</p>
        <% } %>
        <% posts.forEach((post) => { %>
            <div class="card p-3 border-black shadow">
                <h2><%= post.title %></h2>
                <p><%= post.message %></p>
                <% if(isMember) { %>
                    <p>
                        <%= new Date(post.timestamp).toLocaleString('en-US', {
                            month: 'short',
                            day: 'numeric',
                            year: 'numeric',
                            hour: '2-digit',
                            minute: '2-digit'
                        }) %>
                    </p>
                    <p><%= post.f_name %> <%= post.l_name %></p>
                <% } else { %>
                    <small class="text-muted">Only members can view the authors and the creation date</small>
                <% } %>
    
                <% if(isAdmin) { %>
                    <form action="/delete-post/<%= post.id %>" method="POST">
                        <button type="submit" class="border border-black rounded bg-danger text-white p-1">Delete Post</button>
                    </form>
                <% } %>
    
            </div>
        <% }) %>
    </div>
</div>