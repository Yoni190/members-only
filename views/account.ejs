<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Account</title>
</head>
<body>
    <h1>Account</h1>
    
    <div>
        <label for="f_name">First Name</label>
        <p><%= user.f_name %></p>
    </div>
    
    <div>
        <label for="l_name">Last Name</label>
        <p><%= user.l_name %></p>
    </div>

    <div>
        <label for="memebership">Membership Status</label>
        <% if(user.membership) { %>
            <p>Active</p>
        <% } else {%>
            <p>Not Active</p>
        <% } %>

        <a href="/activate-membership">Activate Membership</a>
    </div>

</body>
</html>